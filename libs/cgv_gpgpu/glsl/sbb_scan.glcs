//?#version 430

// Shader Building Blocks (SBB). Reusable components for compute shaders.

//?#include "sbb_macros.glcs"

// The template-like macros in this file generate functions that perform scan operations on a range of data.

#define CGV_SBB_INTERNAL_GROUP_SCAN_BASE_ADDR \
	int ai = offset*(2*tid + 1) - 1; \
	int bi = offset*(2*tid + 2) - 1;

#ifdef CGV_SBB_SCAN_USE_ADDRESS_OFFSET
#define CGV_SBB_INTERNAL_GROUP_SCAN_ADDR \
	CGV_SBB_INTERNAL_GROUP_SCAN_BASE_ADDR \
	ai += CGV_SBB_CONFLICT_FREE_OFFSET(ai); \
	bi += CGV_SBB_CONFLICT_FREE_OFFSET(bi);

#else
#define CGV_SBB_INTERNAL_GROUP_SCAN_ADDR CGV_SBB_INTERNAL_GROUP_SCAN_BASE_ADDR

#endif

#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(N, BUFFER, OPERATION) \
barrier(); \
if(tid < N) { \
	CGV_SBB_INTERNAL_GROUP_SCAN_ADDR \
	BUFFER[bi] = OPERATION(BUFFER[ai], BUFFER[bi]); \
} \
offset += offset;

#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_1(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(1, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_2(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(2, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_1(BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_4(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(4, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_2(BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_8(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(8, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_4(BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_16(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(16, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_8(BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_32(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(32, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_16(BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_64(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(64, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_32(BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_128(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(128, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_64(BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_256(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(256, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_128(BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_512(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(512, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_256(BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_UPSWEEP_1024(BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_FUNC(1024, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_UPSWEEP_512(BUFFER, OPERATION)

#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(N, VALUE_TYPE, BUFFER, OPERATION) \
offset >>= 1; \
barrier(); \
if(tid < N) { \
	CGV_SBB_INTERNAL_GROUP_SCAN_ADDR \
	VALUE_TYPE temp = BUFFER[ai]; \
	BUFFER[ai] = BUFFER[bi]; \
	BUFFER[bi] = OPERATION(BUFFER[bi], temp); \
} \

#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_1(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(1, VALUE_TYPE, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_2(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_1(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(2, VALUE_TYPE, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_4(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_2(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(4, VALUE_TYPE, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_8(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_4(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(8, VALUE_TYPE, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_16(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_8(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(16, VALUE_TYPE, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_32(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_16(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(32, VALUE_TYPE, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_64(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_32(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(64, VALUE_TYPE, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_128(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_64(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(128, VALUE_TYPE, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_256(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_128(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(256, VALUE_TYPE, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_512(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_256(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(512, VALUE_TYPE, BUFFER, OPERATION)
#define CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_1024(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_512(VALUE_TYPE, BUFFER, OPERATION) CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_FUNC(1024, VALUE_TYPE, BUFFER, OPERATION)

// Defines a group-wide scan consisting of up- and downsweep procedures over an array of 2 * THREADS_PER_GROUP length using BINARY_OPERATION.
// A complete scan consists of a call to NAME_upsweep followed by NAME_downsweep (see example usage below).
// THREADS_PER_GROUP must be a power of two in the range [2, 1024].
// BUFFER must point to a consecutive range of shared memory.
// BINARY_OPERATION must specify a function with two parameters of the same data type as in BUFFER and must return a singular value of the same type.
// The generated functions must be called with at least THREADS_PER_GROUP consecutive active threads beginning at id 0.
//
// The function NAME_upsweep will return an offset that may not be altered and is used as the argument to the downsweep phase.
// After the call to NAME_upsweep, BUFFER[2 * THREADS_PER_GROUP - 1] will contain the last result of the scan. In a standard procedue, the thread with id zero would extract this result if needed and then
// set BUFFER[2 * THREADS_PER_GROUP - 1] to zero or an initial scan start value.
// After the call to NAME_downsweep, BUFFER[i] and BUFFER[i + THREADS_PER_GROUP] will contain the partial prefix results of thread i.
//
// Example usage:
//
// int thread_id = id of thread from 0...THREADS_PER_GROUP-1
// int offset = NAME_upsweep(thread_id);
// 
// if(tid < 1) {
// 	 int total_scan_result = BUFFER[2 * THREADS_PER_GROUP - 1]; // use result where needed
// 	 BUFFER[2* THREADS_PER_GROUP - 1] = 0;
// }
//
// NAME_downsweep(thread_id, offset);
// 
#define CGV_SBB_GROUP_SCAN(NAME, VALUE_TYPE, THREADS_PER_GROUP, BUFFER, BINARY_OPERATION) \
int CGV_SBB_INTERNAL_CONCAT_SYMBOLS(NAME, _upsweep)(in int tid) { \
	int offset = 1; \
	CGV_SBB_INTERNAL_CONCAT_SYMBOLS(CGV_SBB_INTERNAL_GROUP_UPSWEEP_, THREADS_PER_GROUP)(BUFFER, BINARY_OPERATION) \
	return offset; \
} \
void CGV_SBB_INTERNAL_CONCAT_SYMBOLS(NAME, _downsweep)(in int tid, in int offset) { \
	CGV_SBB_INTERNAL_CONCAT_SYMBOLS(CGV_SBB_INTERNAL_GROUP_DOWNSWEEP_, THREADS_PER_GROUP)(VALUE_TYPE, BUFFER, BINARY_OPERATION) \
	barrier(); \
}

