#version 430

#include "gpgpu_radix_sort_onesweep_common.glcs"

layout(local_size_x = 256) in;

void main() {
	uvec3 id = gl_GlobalInvocationID;

	const uint increment = 256 * 256;
	const uint clear_end = u_thread_blocks * RADIX * RADIX_PASSES;
	for(uint i = id.x; i < clear_end; i += increment)
		b_pass_hist[i] = 0;

	if(id.x < RADIX * RADIX_PASSES)
		b_global_hist[id.x] = 0;
	
	if(id.x < RADIX_PASSES)
		b_index[id.x] = 0;
}
