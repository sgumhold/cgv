#version 430

//$cgv::input_type_def
//$cgv::output_type_def

//$cgv::typedefs

layout(std430, binding = 0) readonly buffer input_buffer {
	input_type data_in[];
};

layout(std430, binding = 1) writeonly buffer output_buffer {
	output_type data_out[];
};

uniform uint u_count;

//$cgv::arguments

output_type operation(input_type element, uint index) {
	//$cgv::operation
}

layout(local_size_x = 512) in;
void main() {
	uint gid = gl_GlobalInvocationID.x;

	if(gid < u_count)
		data_out[gid] = operation(data_in[gid], gid);
}
