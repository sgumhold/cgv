#version 430

#include "gpgpu_args.glcs"

//$cgv::value_typedef

layout(std430, binding = 0) buffer value_buffer {
	value_type data[];
};

uniform uint u_count;
uniform value_type u_init;
uniform value_type u_step;

layout(local_size_x = 512) in;
void main() {
	uint gid = gl_GlobalInvocationID.x;

	if(gid < u_count)
		data[gid] = u_init + u_step * value_type(gid);
}
