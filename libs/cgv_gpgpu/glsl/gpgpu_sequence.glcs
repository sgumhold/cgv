#version 430

#include "gpgpu_args.glcs"

//$cgv::value_typedef

layout(std430, binding = 0) buffer value_buffer {
	value_type data[];
};

uniform uint u_begin;
uniform uint u_end;
uniform value_type u_init;
uniform value_type u_step;

layout(local_size_x = 512) in;
void main() {
	uint gid = gl_GlobalInvocationID.x;
	uint id = u_begin + gid;

	if(id < u_end)
		data[id] = u_init + u_step * value_type(gid);
}
