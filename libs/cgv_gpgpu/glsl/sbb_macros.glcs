//?#version 430

// Shader Building Blocks (SBB). Reusable components for compute shaders.

// This file defines replacement macros that are used throughout the rest of the SBB library.

#define CGV_SBB_INTERNAL_CONCAT_SYMBOLS(A, B) A ## B

#define CGV_SBB_INTERNAL_NUM_BANKS 32
#define CGV_SBB_INTERNAL_LOG_NUM_BANKS 5
// Compute an offset of 1 for every 32 steps to avoid bank conflicts.
#define CGV_SBB_CONFLICT_FREE_OFFSET(N)((N) >> CGV_SBB_INTERNAL_LOG_NUM_BANKS)
