    env::CESIUM_DIR."/Cesium3DTilesWriter/include/",
    env::CESIUM_DIR."/Cesium3DTilesWriter/generated/include/",
    env::CESIUM_DIR."/CesiumAsync/include/",
    env::CESIUM_DIR."/CesiumClientCommon/include/",
    env::CESIUM_DIR."/CesiumCurl/include/",
    env::CESIUM_DIR."/CesiumGeometry/include/",
    env::CESIUM_DIR."/CesiumGeospatial/include/",
    env::CESIUM_DIR."/CesiumGltf/include/",
    env::CESIUM_DIR."/CesiumGltf/generated/include/",
