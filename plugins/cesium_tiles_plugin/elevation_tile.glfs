#version 430

in vec3 normal_fs;
in vec2 texcoord_fs;

uniform sampler2D texture;

out vec4 frag_color;

void main()
{
    // TODO: replace random calculations with proper lighting calculations
    float intensity = min(1.0, max(max(texcoords_fs.x, texcoords_fs.y), dot(normal_fs, vec3(0, 1, 0))));

    //frag_color = vec4(1.0, 0.0, 0.0, 1.0) * intensity;

    frag_color = texture2D(texture, texcoord_fs);
}